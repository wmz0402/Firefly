---
import { getLqipProps } from "@/utils/lqip-utils";

interface Props {
	src: string;
	albumId: string;
	alt?: string;
}

const { src, albumId, alt = "" } = Astro.props;

const isRemote = /^(https?:)?\/\//i.test(src);
const lqipProps = !isRemote ? getLqipProps(src, undefined, true) : { style: "" };
---

<div class="gallery-photo-card break-inside-avoid mb-3">
  <div
    data-fancybox={`gallery-${albumId}`}
    data-src={src}
    data-type="image"
    class="block rounded-xl overflow-hidden relative group cursor-pointer"
  >
    {!isRemote && (
      <div class="lqip-placeholder absolute inset-0 pointer-events-none" style={lqipProps.style} aria-hidden="true"></div>
    )}
    <img
      src={src}
      alt={alt}
      loading="lazy"
      decoding="async"
      class:list={[
        "w-full h-auto object-cover transition-all duration-500 ease-out group-hover:scale-105",
        !isRemote && "opacity-0"
      ]}
    />
  </div>
</div>
